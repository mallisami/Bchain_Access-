# BCHAIN-ACCESS Configuration Example File (.env)
# Rename this file to '.env' and place it in the appropriate directories (e.g. backend/ or smart_contracts/ or project root).

# Flask Backend Settings
SECRET_KEY=your-secret-key-here-for-production
FLASK_DEBUG=False

# Blockchain Settings
WEB3_PROVIDER_URL=http://localhost:8545
CONTRACT_ADDRESS=0x5FbDB2315678afecb367f032d93F642f64180aa3
CONTRACT_ABI_PATH=../../experiments/hardhat/artifacts/contracts/HealthAccessControl.sol/HealthAccessControl.json

# Development / Demo Flag
DEMO_MODE=true

# Private Key (Keep this secret and never check into source control!)
# In DEMO_MODE=true, leaving this empty will default to the known Hardhat test account.
# In production, set this to your real patient account private key.
PATIENT_PRIVATE_KEY=
